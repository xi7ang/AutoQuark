# AutoQuark 环境变量配置
# 复制本文件为 .env，填入真实值后即可使用
# 敏感信息不要提交到 Git

# ══════════════════════════════════════════════════════
# 必填项
# ══════════════════════════════════════════════════════

# QuarkPanTool 仓库本地路径
QUARK_PAN_TOOL_ROOT=

# mswnlz 内容仓库根目录（包含 book、movies 等仓库）
MSWNLZ_ROOT=

# 站点仓库路径（<username>.github.io）
MSWNLZ_SITE_REPO_DIR=

# Quark cookies 文件路径
QUARK_COOKIES_FILE=

# 你的 GitHub 用户名（用于发布内容）
MSWNLZ_GITHUB_OWNER=

# 资源保存目标文件夹 FID（从夸克网盘复制文件夹链接中获取）
QUARK_TARGET_DIR_ID=

# ══════════════════════════════════════════════════════
# 可选：Telegram 通知
# ══════════════════════════════════════════════════════

# Telegram Bot Token（找 @BotFather 申请）
TELEGRAM_BOT_TOKEN=

# 群组 ID（去掉 -100 前缀，只填数字部分；或完整数字）
TG_GROUP_1_ID=
TG_GROUP_1_THREAD=
TG_GROUP_2_ID=
TG_GROUP_2_THREAD=
TG_GROUP_3_ID=
TG_GROUP_3_THREAD=

# ══════════════════════════════════════════════════════
# 可选：AI 能力
# ══════════════════════════════════════════════════════

# MiniMax API Key（用于生成资源简介）
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ══════════════════════════════════════════════════════
# 可选：推广文件
# ══════════════════════════════════════════════════════

# 推广文件所在文件夹 FID（可选）
QUARK_PROMO_FOLDER_FID=

# 或用网盘路径代替 FID（可选）
QUARK_PROMO_FOLDER_PATH=

# ══════════════════════════════════════════════════════
# 可选：资源导航 Bot
# ══════════════════════════════════════════════════════

# 资源机器人 Webhook 地址（可选）
BOT_API_URL=

# Bot 开始的 URL 前缀，如 https://t.me/yourbot?start=
BOT_START_URL_BASE=

# ══════════════════════════════════════════════════════
# 可选：站点
# ══════════════════════════════════════════════════════

# 站点域名
SITE_URL=https://your-site.example.com

# 站点后缀
SITE_SUFFIX=
